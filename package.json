{
  "name": "pokemon-matchups",
  "version": "0.1.0",
  "private": true,
  "description": "Tools to generate matchup outputs from Showdown set libraries",
  "scripts": {
    "matchups:test1": "node scripts/generate-matchups.js libraries/test_set_1.txt",
    "matchups:test2": "node scripts/generate-matchups.js libraries/test_set_2.txt",
    "rank:champions": "node scripts/rank-matchups.js --input matchups/champions_ou_matchups.json --rulebook kill-tier-speed-priority-v1",
    "return-matchups": "node scripts/return-matchups.js return-matchups",
    "test": "node --test tests/*.test.js"
  },
  "dependencies": {
    "@smogon/calc": "^0.10.0"
  }
}
